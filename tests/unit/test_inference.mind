// Forward-path wiring: score_against_routes + preselect_pre_tokenized.
//
// Targets:
//   - src/model.mind :: score_against_routes  (Part A, scoring head)
//   - src/inference.mind :: preselect_pre_tokenized (Part B, orchestration)
//   - src/inference.mind :: InferenceError    (Part C, error surface)
//
// Bit-identity contract (spec/numerics.md §"Pinned reductions"):
//   score_against_routes[b, r] MUST equal q16_dot_pinned(query[b], routes[r])
//   for every (b, r). Any vectorised lowering that produces a different byte
//   pattern violates E_NERVE_001 (forward-path matmul) and E_NERVE_003
//   (Q16.16 saturating MAC).
//
// Q16.16 encoding: integer value V encodes as (V << 16) in i32.

use crate::mind_nerve::{
    Q16_16,
    ENCODER_HIDDEN,
    ROUTE_EMBEDDING_DIM,
    MAX_TOP_K,
    MAX_REQUEST_TOKENS,
    ATTESTATION_BYTES,
};
use crate::mind_nerve::model;
use crate::mind_nerve::model::score_against_routes;
use crate::mind_nerve::inference::{
    preselect_pre_tokenized,
    InferenceError,
    PreselectResult,
    RouteCatalog,
    UniqueRouteCatalog,
    RouteId,
    ModelWeights,
};
use crate::mind_nerve::q16_16::q16_dot_pinned;
use crate::mind_nerve::sha256::sha256;

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

// q16(v): encode integer v as Q16.16 i32. Works for negative v.
fn q16(v: i32) -> Q16_16 {
    v << 16
}

// Build a [1, ENCODER_HIDDEN] tensor with a single non-zero at index `i`,
// value q16(scale).
fn one_hot_query(i: usize, scale: i32) -> tensor<Q16_16, [1, ENCODER_HIDDEN]> {
    let mut row: [Q16_16; ENCODER_HIDDEN] = [0_i32; ENCODER_HIDDEN];
    row[i] = q16(scale);
    [row]
}

// Build a num_routes x ROUTE_EMBEDDING_DIM tensor where row r holds value
// q16(r+1) at index `i` (matching the one_hot_query slot) and zero elsewhere.
fn diagonal_routes(num_routes: usize, i: usize) -> tensor<Q16_16, [num_routes, ROUTE_EMBEDDING_DIM]> {
    let mut t: tensor<Q16_16, [num_routes, ROUTE_EMBEDDING_DIM]> =
        [[0_i32; ROUTE_EMBEDDING_DIM]; num_routes];
    let mut r: usize = 0;
    while r < num_routes {
        t[r][i] = q16((r as i32) + 1_i32);
        r = r + 1;
    }
    t
}

// Build a fully-zero ModelWeights. The encoder bodies in model.mind require
// the full weight manifest, so for tests that exercise the orchestration
// layer without running the encoder we set ENCODER_HIDDEN to 0 weights —
// the encoder still runs (over zero input) and produces zeros, which is
// what we want for purely-orchestration tests.
fn zero_model_weights() -> ModelWeights {
    ModelWeights {
        encoder:        model::EncoderWeights::zeros(),
        model_hash:     [0u8; 32],
        tokenizer_hash: [0u8; 32],
    }
}

// Build a 2-route catalog from two distinct external ids, with zero embeddings.
fn two_route_catalog() -> RouteCatalog {
    let ids: [str; 2] = ["alpha", "beta"];
    let scores: [Q16_16; 2] = [0_i32, 0_i32];
    UniqueRouteCatalog::new(ids, scores).unwrap().as_catalog()
}

// ---------------------------------------------------------------------------
// Part A: score_against_routes — shape + bit-identity to q16_dot_pinned.
// ---------------------------------------------------------------------------

#[test]
fn score_against_routes_shape_matches_inputs() {
    let query  = one_hot_query(0, 1);
    let routes = diagonal_routes(4, 0);

    let logits = score_against_routes(query, routes);

    assert logits.len() == 1, "batch dim preserved";
    assert logits[0].len() == 4, "num_routes dim equals route table rows";
}

#[test]
fn score_against_routes_dot_identity_one_hot() {
    // query is e_0 * 1.0; routes[r][0] = (r+1). So logits[0, r] = (r+1).
    let query  = one_hot_query(0, 1);
    let routes = diagonal_routes(5, 0);

    let logits = score_against_routes(query, routes);

    let mut r: usize = 0;
    while r < 5 {
        let expected: Q16_16 = q16((r as i32) + 1_i32);
        assert logits[0][r] == expected,
            "logits[0, r] must equal route's diagonal value under one-hot query";
        r = r + 1;
    }
}

#[test]
fn score_against_routes_pinned_matches_q16_dot_pinned() {
    // Bit-identity oracle: every (b, r) entry must equal a direct
    // q16_dot_pinned call. This is the lint anchor for E_NERVE_001.
    let mut q_row: [Q16_16; ENCODER_HIDDEN] = [0_i32; ENCODER_HIDDEN];
    let mut k: usize = 0;
    while k < ENCODER_HIDDEN {
        // Alternating signs at modest magnitude — exercises q16_add
        // saturation path without overflowing.
        if (k & 1) == 0 {
            q_row[k] = q16(((k as i32) % 7_i32) + 1_i32);
        } else {
            q_row[k] = q16(-(((k as i32) % 5_i32) + 1_i32));
        }
        k = k + 1;
    }
    let query: tensor<Q16_16, [1, ENCODER_HIDDEN]> = [q_row];

    let num_routes: usize = 3;
    let mut routes: tensor<Q16_16, [num_routes, ROUTE_EMBEDDING_DIM]> =
        [[0_i32; ROUTE_EMBEDDING_DIM]; num_routes];
    let mut r: usize = 0;
    while r < num_routes {
        let mut j: usize = 0;
        while j < ROUTE_EMBEDDING_DIM {
            routes[r][j] = q16((((j + r) as i32) % 11_i32) - 5_i32);
            j = j + 1;
        }
        r = r + 1;
    }

    let logits = score_against_routes(query, routes);

    let mut rr: usize = 0;
    while rr < num_routes {
        let expected: Q16_16 = q16_dot_pinned(&q_row, &routes[rr]);
        assert logits[0][rr] == expected,
            "score_against_routes must be bit-identical to q16_dot_pinned per (b, r)";
        rr = rr + 1;
    }
}

#[test]
fn score_against_routes_zero_query_yields_zeros() {
    let query: tensor<Q16_16, [1, ENCODER_HIDDEN]> = [[0_i32; ENCODER_HIDDEN]];
    let routes = diagonal_routes(8, 3);

    let logits = score_against_routes(query, routes);

    let mut r: usize = 0;
    while r < 8 {
        assert logits[0][r] == 0_i32, "zero query yields zero scores everywhere";
        r = r + 1;
    }
}

// ---------------------------------------------------------------------------
// Part C: InferenceError surface on preselect_pre_tokenized.
// ---------------------------------------------------------------------------

#[test]
fn preselect_rejects_k_zero() {
    let catalog = two_route_catalog();
    let weights = zero_model_weights();
    let tokens: [u32; 1] = [42u32];

    let result = preselect_pre_tokenized(&tokens, &catalog, &weights, 0u32);

    match result {
        Err(InferenceError::InvalidK) => { /* expected */ }
        _ => { assert false, "k == 0 must yield InvalidK"; }
    }
}

#[test]
fn preselect_rejects_k_above_max() {
    let catalog = two_route_catalog();
    let weights = zero_model_weights();
    let tokens: [u32; 1] = [42u32];

    let result = preselect_pre_tokenized(&tokens, &catalog, &weights, MAX_TOP_K + 1u32);

    match result {
        Err(InferenceError::InvalidK) => { /* expected */ }
        _ => { assert false, "k > MAX_TOP_K must yield InvalidK"; }
    }
}

#[test]
fn preselect_rejects_oversize_token_stream() {
    let catalog = two_route_catalog();
    let weights = zero_model_weights();

    // MAX_REQUEST_TOKENS + 1 tokens, all zero. Avoid running the encoder by
    // tripping the length gate before forward compute.
    let n: usize = (MAX_REQUEST_TOKENS as usize) + 1;
    let mut tokens: [u32; n] = [0u32; n];

    let result = preselect_pre_tokenized(&tokens, &catalog, &weights, 1u32);

    match result {
        Err(InferenceError::RequestTooLong) => { /* expected */ }
        _ => { assert false, "len > MAX_REQUEST_TOKENS must yield RequestTooLong"; }
    }
}

#[test]
fn preselect_rejects_empty_catalog() {
    let empty_catalog: RouteCatalog =
        UniqueRouteCatalog::new([], []).unwrap().as_catalog();
    let weights = zero_model_weights();
    let tokens: [u32; 1] = [42u32];

    let result = preselect_pre_tokenized(&tokens, &empty_catalog, &weights, 1u32);

    match result {
        Err(InferenceError::EmptyCatalog) => { /* expected */ }
        _ => { assert false, "empty catalog must yield EmptyCatalog"; }
    }
}

// ---------------------------------------------------------------------------
// Validation precedence — k checked before length, length before catalog.
// ---------------------------------------------------------------------------
//
// Ordering matters: a request that is both oversize AND has bad k should
// fail closed on k first, because k is the cheaper check and the field with
// the most attacker leverage (it controls envelope.k which is wire-visible).
// This regression-guards the InferenceError gate sequence in preselect().

#[test]
fn preselect_k_check_precedes_length_check() {
    let catalog = two_route_catalog();
    let weights = zero_model_weights();
    let n: usize = (MAX_REQUEST_TOKENS as usize) + 1;
    let mut tokens: [u32; n] = [0u32; n];

    // k == 0 AND oversize tokens. Must report InvalidK, not RequestTooLong.
    let result = preselect_pre_tokenized(&tokens, &catalog, &weights, 0u32);

    match result {
        Err(InferenceError::InvalidK) => { /* expected */ }
        _ => { assert false, "k check must precede length check"; }
    }
}

#[test]
fn preselect_length_check_precedes_empty_catalog_check() {
    let empty_catalog: RouteCatalog =
        UniqueRouteCatalog::new([], []).unwrap().as_catalog();
    let weights = zero_model_weights();
    let n: usize = (MAX_REQUEST_TOKENS as usize) + 1;
    let mut tokens: [u32; n] = [0u32; n];

    // Oversize tokens AND empty catalog. Must report RequestTooLong first.
    let result = preselect_pre_tokenized(&tokens, &empty_catalog, &weights, 1u32);

    match result {
        Err(InferenceError::RequestTooLong) => { /* expected */ }
        _ => { assert false, "length check must precede empty-catalog check"; }
    }
}

// ---------------------------------------------------------------------------
// Envelope shape — when the forward path runs, the envelope is exactly
// ATTESTATION_BYTES (= 212) bytes. The byte-level field-by-field contract
// lives in tests/unit/test_evidence.mind §1; here we only assert the size
// and that we got an Ok result with a non-empty result list.
// ---------------------------------------------------------------------------

#[test]
fn preselect_envelope_is_212_bytes() {
    let catalog = two_route_catalog();
    let weights = zero_model_weights();
    let tokens: [u32; 4] = [1u32, 2u32, 3u32, 4u32];

    let result = preselect_pre_tokenized(&tokens, &catalog, &weights, 1u32);

    match result {
        Ok(pr) => {
            assert pr.envelope.len() == (ATTESTATION_BYTES as usize),
                "envelope must be exactly ATTESTATION_BYTES = 212 bytes";
            assert pr.route_ids.len() == 1, "k == 1 yields one route id";
            assert pr.scores.len() == 1,    "k == 1 yields one score";
        }
        Err(_) => {
            assert false, "forward path must succeed on well-formed inputs";
        }
    }
}
