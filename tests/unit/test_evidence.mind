        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::ClockReset,
    );
    let (env, _) = verify(bytes, zeros32()).unwrap();
    assert_eq!(env.chain_reset_reason, 3u16);
}

// ---------------------------------------------------------------------------
// §6. Version field
// ---------------------------------------------------------------------------

// verify() accepts version=2 envelopes.
#[test]
fn test_envelope_version_2_is_accepted() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    // Sanity: version byte at offset 0 must be 2.
    assert_eq!(bytes[0], 2u8);
    let result = verify(bytes, zeros32());
    assert!(result.is_ok());
}

// v1 envelopes must be rejected. Forcibly write 1 into offset 0.
// (v1 has no production users — safe to make a hard break.)
#[test]
fn test_envelope_version_1_is_rejected() {
    let mut bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    bytes[0] = 1u8;  // downgrade version byte
    let result = verify(bytes, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::VersionUnsupported);
}

// Future version 99 must be rejected with an "unknown version" error,
// not silently accepted, to prevent future format skew.
#[test]
fn test_envelope_version_99_is_rejected_as_unknown() {
    let mut bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    bytes[0] = 99u8;  // unknown future version
    let result = verify(bytes, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::VersionUnsupported);
}

// ---------------------------------------------------------------------------
// §7. Reserved field
// ---------------------------------------------------------------------------

// reserved byte at offset 17 must be 0; any other value → verify error.
// This guards the byte against accidental re-use before it is officially
// allocated to a new field in a future version.
#[test]
fn test_envelope_reserved_must_be_zero() {
    let mut bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    bytes[17] = 0xAAu8;  // non-zero reserved byte
    let result = verify(bytes, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::ReservedByteNonZero);
}

// Confirm emit() writes 0 into the reserved byte.
#[test]
fn test_envelope_emit_sets_reserved_to_zero() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert_eq!(bytes[17], 0u8);
}

// ---------------------------------------------------------------------------
// §8. wire_version binding (audit A4)
// ---------------------------------------------------------------------------

// Two envelopes differing ONLY in wire_version must have distinct chain_curr.
// Prevents replaying Phase 1 envelopes as Phase 2 envelopes across a wire
// schema bump.
#[test]
fn test_chain_wire_version_enters_chain_curr() {
    let make_chain_curr = |wv: u16| -> [u8; 32] {
        let bytes = emit(
            PLACEHOLDER_HASH_MODEL,
            PLACEHOLDER_HASH_TOKENIZER,
            PLACEHOLDER_HASH_CATALOG,
            PLACEHOLDER_HASH_REQUEST,
            PLACEHOLDER_HASH_RESULT,
            k             = DEFAULT_K,
            wire_version  = wv,
            architecture  = DEFAULT_ARCH,
            timestamp_ms  = DEFAULT_TIMESTAMP,
            entry_kind    = EntryKind::Inference,
            chain_prev    = zeros32(),
            chain_reset_reason = ChainResetReason::Continuation,
        );
        let (_, cc) = verify(bytes, zeros32()).unwrap();
        cc
    };

    let cc_v1 = make_chain_curr(1);
    let cc_v2 = make_chain_curr(2);
    assert_ne!(cc_v1, cc_v2);
}

// ---------------------------------------------------------------------------
// §9. k binding (audit A4)
// ---------------------------------------------------------------------------

// Two envelopes differing ONLY in k must have distinct chain_curr.
// An envelope for k=5 cannot be replayed as evidence of a k=64 request.
#[test]
fn test_chain_k_enters_chain_curr() {
    let make_chain_curr = |top_k: u32| -> [u8; 32] {
        let bytes = emit(
            PLACEHOLDER_HASH_MODEL,
            PLACEHOLDER_HASH_TOKENIZER,
            PLACEHOLDER_HASH_CATALOG,
            PLACEHOLDER_HASH_REQUEST,
            PLACEHOLDER_HASH_RESULT,
            k             = top_k,
            wire_version  = DEFAULT_WIRE_VERSION,
            architecture  = DEFAULT_ARCH,
            timestamp_ms  = DEFAULT_TIMESTAMP,
            entry_kind    = EntryKind::Inference,
            chain_prev    = zeros32(),
            chain_reset_reason = ChainResetReason::Continuation,
        );
        let (_, cc) = verify(bytes, zeros32()).unwrap();
        cc
    };

    let cc_k5  = make_chain_curr(5);
    let cc_k64 = make_chain_curr(64);
    assert_ne!(cc_k5, cc_k64);
}

// Specifically test the k=5 vs k=64 replay scenario mentioned in audit A4.
#[test]
fn test_chain_k5_envelope_cannot_be_replayed_as_k64() {
    let bytes_k5 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = 5u32,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env_k5, chain_curr_k5) = verify(bytes_k5, zeros32()).unwrap();
    assert_eq!(env_k5.k, 5u32);

    // Build the k=64 envelope that claims the same chain_curr as its chain_prev.
    // This would be the adversarial replay: pass k5's chain_curr as if it were
    // the predecessor of a k64 envelope.
    let bytes_k64 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = 64u32,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 1,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_k5,   // attempts to splice into k5's chain
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env_k64, chain_curr_k64) = verify(bytes_k64, chain_curr_k5).unwrap();
    assert_eq!(env_k64.k, 64u32);
    // The two chain_curr values are distinct — the hash encodes k.
    assert_ne!(chain_curr_k5, chain_curr_k64);
}

// ---------------------------------------------------------------------------
// §10. tokenizer_hash binding (audit A4)
// ---------------------------------------------------------------------------

// Two envelopes differing ONLY in tokenizer_hash must have distinct chain_curr.
// A tokenizer swap (same model weights, different BPE table) MUST produce a
// fresh chain link and NOT silently match a prior envelope.
#[test]
fn test_chain_tokenizer_hash_enters_chain_curr() {
    let make_chain_curr = |tok_hash: [u8; 32]| -> [u8; 32] {
        let bytes = emit(
            PLACEHOLDER_HASH_MODEL,
            tok_hash,
            PLACEHOLDER_HASH_CATALOG,
            PLACEHOLDER_HASH_REQUEST,
            PLACEHOLDER_HASH_RESULT,
            k             = DEFAULT_K,
            wire_version  = DEFAULT_WIRE_VERSION,
            architecture  = DEFAULT_ARCH,
            timestamp_ms  = DEFAULT_TIMESTAMP,
            entry_kind    = EntryKind::Inference,
            chain_prev    = zeros32(),
            chain_reset_reason = ChainResetReason::Continuation,
        );
        let (_, cc) = verify(bytes, zeros32()).unwrap();
        cc
    };

    let tokenizer_v1 = [0xAAu8; 32];
    let tokenizer_v2 = [0xBBu8; 32];
    assert_ne!(make_chain_curr(tokenizer_v1), make_chain_curr(tokenizer_v2));
}

// Tokenizer-swap scenario: same model, same request, different BPE table.
// The two envelopes must have distinct chain_curr, so they cannot be
// mistaken for each other in a chain verification pass.
#[test]
fn test_chain_tokenizer_swap_produces_fresh_chain_link() {
    let tokenizer_bpe32k    = [0xC0u8; 32];  // 32k BPE table hash
    let tokenizer_bpe48k    = [0xC1u8; 32];  // 48k BPE table hash (Phase 2 candidate)

    let bytes_32k = emit(
        PLACEHOLDER_HASH_MODEL,
        tokenizer_bpe32k,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_32k, chain_curr_32k) = verify(bytes_32k, zeros32()).unwrap();

    let bytes_48k = emit(
        PLACEHOLDER_HASH_MODEL,
        tokenizer_bpe48k,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_48k, chain_curr_48k) = verify(bytes_48k, zeros32()).unwrap();

    // The two chain_curr values must differ because tokenizer_hash differs.
    assert_ne!(chain_curr_32k, chain_curr_48k);
}

// ---------------------------------------------------------------------------
// §11. Edge cases and error paths
// ---------------------------------------------------------------------------

// Empty / short byte slice must be rejected, not panic.
#[test]
fn test_envelope_verify_rejects_empty_bytes() {
    let result = verify([], zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::InvalidLength);
}

// Byte slice shorter than 212 bytes must be rejected.
#[test]
fn test_envelope_verify_rejects_truncated_bytes() {
    let result = verify([0u8; 100], zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::InvalidLength);
}

// Byte slice longer than 212 bytes must be rejected (no trailing garbage).
#[test]
fn test_envelope_verify_rejects_oversized_bytes() {
    let result = verify([0u8; 300], zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::InvalidLength);
}

// An invalid entry_kind value (e.g. 0 or 255) must be rejected.
#[test]
fn test_envelope_verify_rejects_unknown_entry_kind() {
    let mut bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    bytes[1] = 0u8;  // 0 is not a valid EntryKind (1-based enum)
    let result = verify(bytes, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::InvalidEntryKind);
}

#[test]
fn test_envelope_verify_rejects_entry_kind_255() {
    let mut bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    bytes[1] = 255u8;  // out-of-range entry_kind
    let result = verify(bytes, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::InvalidEntryKind);
}

// k=0 is below the MIN_TOP_K boundary; emit must reject it.
#[test]
fn test_envelope_emit_rejects_k_zero() {
    let result = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
