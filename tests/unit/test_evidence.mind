        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert!(result.is_err());
}

// k > MAX_TOP_K (64) must be rejected; spec §architecture.md line 19.
#[test]
fn test_envelope_emit_rejects_k_above_max() {
    let result = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
