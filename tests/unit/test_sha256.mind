        [0x45, 0x0A, 0xBB, 0xB7, 0x24, 0x6A, 0x69, 0x7D, 0x26, 0xD7, 0x32, 0x07, 0xA5, 0xD8, 0x61, 0x02, 0xA8, 0x78, 0x60, 0xDA, 0x9D, 0xA2, 0x67, 0xC8, 0x97, 0xA7, 0xC2, 0x30, 0x7F, 0x31, 0x0F, 0x0D],
        [0x40, 0xFC, 0x9D, 0x2B, 0xDE, 0xC1, 0x74, 0x98, 0x0C, 0xF1, 0x17, 0x5F, 0xDF, 0x50, 0xD7, 0x43, 0xC1, 0x9D, 0x77, 0xA4, 0x87, 0xB6, 0xF9, 0xF9, 0x7D, 0xD3, 0xA3, 0x58, 0x97, 0x54, 0xB9, 0xDD],
    ];

    // Hash each input, concatenate the 100 digests, then hash the concatenation.
    let mut concat: [u8; 3200] = [0u8; 3200]; // 100 × 32
    for i in 0..100 {
        let digest = sha256(&inputs[i]);
        concat[i * 32 .. (i + 1) * 32].copy_from_slice(&digest);
    }
    let overall = sha256(&concat);

    let want: [u8; 32] = [
        0x28, 0x05, 0x10, 0xDC, 0xFA, 0xE5, 0xD7, 0x9B,
        0x38, 0x03, 0xBA, 0x5B, 0x42, 0x55, 0x02, 0x4D,
        0x9A, 0x32, 0x26, 0x8B, 0x14, 0x74, 0x48, 0x6B,
        0x9A, 0x85, 0xA5, 0x6D, 0x56, 0x96, 0x8B, 0x26,
    ];
    assert_eq!(overall, want);
}

// ---------------------------------------------------------------------------
// Section 4: Streaming vs. one-shot
// ---------------------------------------------------------------------------
// No streaming API is exposed on `inference::sha256`; it is one-shot only.
// Chain composition is done at the caller level (evidence::emit concatenates
// fields and calls sha256 once).
//
// If a streaming API (`Sha256State::new/update/finalize`) is added in future,
// add streaming tests here and remove this comment.

// No streaming API exposed; one-shot only.

#[test]
fn test_sha256_oneshot_split_input_is_not_streaming() {
    // Property: concatenating two byte slices before calling sha256 produces
    // the same result as concatenating logically — the caller must pre-assemble
    // the input; sha256 is not aware of call history.
    let combined: [u8; 3] = [b'a', b'b', b'c'];
    let got      = sha256(&combined);
    let want: [u8; 32] = [
        0xBA, 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA,
        0x41, 0x41, 0x40, 0xDE, 0x5D, 0xAE, 0x22, 0x23,
        0xB0, 0x03, 0x61, 0xA3, 0x96, 0x17, 0x7A, 0x9C,
        0xB4, 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_oneshot_prefix_empty_does_not_alter_result() {
    // Property: prepending zero bytes to input must not change the digest.
    // Catches any accidental length encoding that differs for empty prefix.
    let input_plain:        [u8; 3] = [b'a', b'b', b'c'];
    let input_zero_prefix:  [u8; 3] = [b'a', b'b', b'c']; // same bytes, no prefix
    let got_plain  = sha256(&input_plain);
    let got_prefix = sha256(&input_zero_prefix);
    assert_eq!(got_plain, got_prefix);
}

// ---------------------------------------------------------------------------
// Section 5: Q16.16 binding — hash of canonical attestation envelope
// ---------------------------------------------------------------------------
// Tests that sha256 applied to a synthetic 172-byte attestation preimage
// matches a hardcoded fixture.  The byte layout is the canonical preimage
// used by evidence::emit (all fields up to and including chain_prev,
// little-endian where applicable, packed with no padding):
//
//   version      : u8          = 0x02
//   entry_kind   : u8          = 0x01  (inference)
//   model_hash   : [u8; 32]    = 0xAA * 32
//   catalog_hash : [u8; 32]    = 0xBB * 32
//   request_hash : [u8; 32]    = 0xCC * 32
//   result_hash  : [u8; 32]    = 0xDD * 32
//   k            : u8          = 0x05
//   timestamp_ms : u64 LE      = 1_000_000 (0x00_00_00_00_00_0F_42_40)
//   architecture : u8          = 0x01  (cpu_arm per evidence::Architecture)
//   chain_prev   : [u8; 32]    = 0xEE * 32
//
// Total: 1+1+32+32+32+32+1+8+1+32 = 172 bytes.
// chain_curr is sha256(this 172-byte preimage).
//
// NOTE: The architecture.md spec states 132 bytes per envelope.  That count
// refers to the v1 struct (no entry_kind, no k field).  This test fixture
// uses v2 fields as specified in the task; the authoritative byte count for
// the preimage tested here is 172.

#[test]
fn test_sha256_attestation_envelope_v2_synthetic_fixture() {
    // Property: sha256 of a fully-specified synthetic envelope preimage matches
    // the hardcoded audit anchor.  Catches any endianness or field-ordering
    // error in evidence::emit's serialization path.
    let mut preimage: [u8; 172] = [0u8; 172];
    let mut off: usize = 0;

    // version = 2
    preimage[off] = 0x02; off += 1;
    // entry_kind = 1 (inference)
    preimage[off] = 0x01; off += 1;
    // model_hash = 0xAA * 32
    for i in 0..32 { preimage[off + i] = 0xAA; } off += 32;
    // catalog_hash = 0xBB * 32
    for i in 0..32 { preimage[off + i] = 0xBB; } off += 32;
    // request_hash = 0xCC * 32
    for i in 0..32 { preimage[off + i] = 0xCC; } off += 32;
    // result_hash = 0xDD * 32
    for i in 0..32 { preimage[off + i] = 0xDD; } off += 32;
    // k = 5
    preimage[off] = 0x05; off += 1;
    // timestamp_ms = 1_000_000 as u64 little-endian
    let ts: u64 = 1_000_000u64;
    let ts_bytes = ts.to_le_bytes();
    for i in 0..8 { preimage[off + i] = ts_bytes[i]; } off += 8;
    // architecture = 1 (CpuArm)
    preimage[off] = 0x01; off += 1;
    // chain_prev = 0xEE * 32
    for i in 0..32 { preimage[off + i] = 0xEE; } off += 32;

    assert_eq!(off, 172, "preimage construction length mismatch");

    let got = sha256(&preimage);

    // Expected: sha256(preimage) computed by Python hashlib.sha256.
    // f62ca51d2ac083e869ee37294f3f2c3e0e71f354df7894c21bb53540b914adcd
    // TODO(P1.1.14): replace PLACEHOLDER_HASH_ENVELOPE_V2 — value is already
    // concrete above; remove this TODO once the implementation is green.
    let want: [u8; 32] = [
        0xF6, 0x2C, 0xA5, 0x1D, 0x2A, 0xC0, 0x83, 0xE8,
        0x69, 0xEE, 0x37, 0x29, 0x4F, 0x3F, 0x2C, 0x3E,
        0x0E, 0x71, 0xF3, 0x54, 0xDF, 0x78, 0x94, 0xC2,
        0x1B, 0xB5, 0x35, 0x40, 0xB9, 0x14, 0xAD, 0xCD,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_attestation_envelope_v2_field_sensitivity() {
    // Property: flipping a single bit in the envelope preimage changes the digest.
    // Ensures the hash actually covers all fields, not a subset.
    let mut preimage: [u8; 172] = [0u8; 172];
    let mut off: usize = 0;
    preimage[off] = 0x02; off += 1;
    preimage[off] = 0x01; off += 1;
    for i in 0..32 { preimage[off + i] = 0xAA; } off += 32;
    for i in 0..32 { preimage[off + i] = 0xBB; } off += 32;
    for i in 0..32 { preimage[off + i] = 0xCC; } off += 32;
    for i in 0..32 { preimage[off + i] = 0xDD; } off += 32;
    preimage[off] = 0x05; off += 1;
    let ts_bytes = 1_000_000u64.to_le_bytes();
    for i in 0..8 { preimage[off + i] = ts_bytes[i]; } off += 8;
    preimage[off] = 0x01; off += 1;
    for i in 0..32 { preimage[off + i] = 0xEE; } off += 32;
    let _ = off;

    let canonical = sha256(&preimage);

    // Flip last byte of chain_prev (byte 171).
    let mut tampered = preimage;
    tampered[171] ^= 0x01;
    let tampered_hash = sha256(&tampered);

    assert_ne!(canonical, tampered_hash,
        "SHA-256 must detect a single-bit change in the attestation preimage");
}

// ---------------------------------------------------------------------------
// Section 6: Output format invariants
// ---------------------------------------------------------------------------

#[test]
fn test_sha256_output_length_is_32_bytes() {
    // Property: the return type is always exactly 32 bytes for any input.
    // This is a type-level guarantee, but we assert it explicitly for inputs
    // at each block boundary to catch any truncation bug.
    let inputs: [&[u8]; 4] = [b"", b"a", b"abcdef", b"The quick brown fox jumps over the lazy dog"];
    for input in &inputs {
        let digest = sha256(input);
        assert_eq!(digest.len(), 32, "digest length for input {:?} must be 32", input);
    }
}

#[test]
fn test_sha256_distinct_inputs_produce_distinct_outputs() {
    // Property: different inputs must produce different digests (no trivial collision).
    let a = sha256(b"route_A");
    let b = sha256(b"route_B");
    assert_ne!(a, b, "sha256(route_A) and sha256(route_B) must differ");
}

#[test]
fn test_sha256_all_zero_vs_all_ones_differ() {
    // Property: all-zero input and all-0xFF input of the same length must differ.
    // Validates that the implementation is not a trivial constant function.
    let zeros = [0x00u8; 32];
    let ones  = [0xFFu8; 32];
    assert_ne!(sha256(&zeros), sha256(&ones));
}

// ---------------------------------------------------------------------------
// Section 7: Tie-break binding (SHA-256 ordering contract)
// ---------------------------------------------------------------------------
// The tie-break used in extract_top_k is `SHA-256(route_id) ascending`.
// These tests verify that the hash values produce a well-defined ordering
// so any future refactor of the comparator still satisfies the spec.

#[test]
fn test_sha256_tiebreak_ordering_is_lexicographic_on_digest_bytes() {
    // Property: two route IDs must have a deterministic ordering derived from
    // byte-by-byte comparison of their SHA-256 digests (not their raw IDs).
    let route_x: [u8; 32] = [0x01u8; 32];
    let route_y: [u8; 32] = [0x02u8; 32];

    let hash_x = sha256(&route_x);
    let hash_y = sha256(&route_y);

    // The ordering must be total and consistent across calls.
    let order_1 = hash_x.cmp(&hash_y);
    let order_2 = hash_x.cmp(&hash_y);
    assert_eq!(order_1, order_2,
        "SHA-256 tie-break ordering must be deterministic across two calls");
}

#[test]
fn test_sha256_tiebreak_reflexive() {
    // Property: SHA-256(route_id) compared with itself is Equal.
    // Guards against accidental pointer comparison instead of value comparison.
    let route: [u8; 32] = [0xABu8; 32];
    let hash = sha256(&route);
    assert_eq!(hash.cmp(&hash), std::cmp::Ordering::Equal);
}

// TODO(P1.1.14): replace PLACEHOLDER_HASH_* after first green run.
