    let rsqadiff_29: i64 = if rsqdiff_29 < 0 { 0 - rsqdiff_29 } else { rsqdiff_29 };
    if rsqadiff_29 > 1 { return 4440064; }
    let sqx_30: i64 = sqrt_q16_lookup(sh, 11771904);
    let sqdiff_30: i64 = sqx_30 - 878341;
    let sqadiff_30: i64 = if sqdiff_30 < 0 { 0 - sqdiff_30 } else { sqdiff_30 };
    if sqadiff_30 > 1 { return 11771904; }
    let rsqx_30: i64 = rsqrt_q16_lookup(rsh, 11771904);
    let rsqdiff_30: i64 = rsqx_30 - 4889;
    let rsqadiff_30: i64 = if rsqdiff_30 < 0 { 0 - rsqdiff_30 } else { rsqdiff_30 };
    if rsqadiff_30 > 1 { return 11771904; }
    let sqx_31: i64 = sqrt_q16_lookup(sh, 4579328);
    let sqdiff_31: i64 = sqx_31 - 547823;
    let sqadiff_31: i64 = if sqdiff_31 < 0 { 0 - sqdiff_31 } else { sqdiff_31 };
    if sqadiff_31 > 1 { return 4579328; }
    let rsqx_31: i64 = rsqrt_q16_lookup(rsh, 4579328);
    let rsqdiff_31: i64 = rsqx_31 - 7840;
    let rsqadiff_31: i64 = if rsqdiff_31 < 0 { 0 - rsqdiff_31 } else { rsqdiff_31 };
    if rsqadiff_31 > 1 { return 4579328; }
    sqrt_q16_free(sh);
    rsqrt_q16_free(rsh);
    0
}

// ── Top-level runner ──────────────────────────────────────────────────────────
// Returns 0 if all smoke tests pass; nonzero on first failure.
pub fn run_all_smoke_tests() -> i64 {
    let r1: i64 = smoke_recip_q32();
    if r1 != 0 { return r1; }
    let r2: i64 = smoke_exp_q16();
    if r2 != 0 { return r2; }
    let r3: i64 = smoke_tanh_q16();
    if r3 != 0 { return r3; }
    let r4: i64 = smoke_softmax_q16();
    if r4 != 0 { return r4; }
    let r5: i64 = smoke_sqrt_q16();
    if r5 != 0 { return r5; }
    0
}
