    assert_eq!(env.entry_kind, EntryKind::CatalogLoad as u8);
}

// Different entry_kind values with all other fields identical must produce
// distinct chain_curr values — entry_kind at offset 1 feeds into SHA-256.
#[test]
fn test_chain_entry_kind_discriminates_chain_curr() {
    let make_bytes = |ek: EntryKind| -> [u8; 32] {
        let bytes = emit(
            PLACEHOLDER_HASH_MODEL,
            PLACEHOLDER_HASH_TOKENIZER,
            PLACEHOLDER_HASH_CATALOG,
            PLACEHOLDER_HASH_REQUEST,
            PLACEHOLDER_HASH_RESULT,
            k             = DEFAULT_K,
            wire_version  = DEFAULT_WIRE_VERSION,
            architecture  = DEFAULT_ARCH,
            timestamp_ms  = DEFAULT_TIMESTAMP,
            entry_kind    = ek,
            chain_prev    = zeros32(),
            chain_reset_reason = ChainResetReason::Continuation,
        );
        let (_, chain_curr) = verify(bytes, zeros32()).unwrap();
        chain_curr
    };

    let cc_inference    = make_bytes(EntryKind::Inference);
    let cc_model_load   = make_bytes(EntryKind::ModelLoad);
    let cc_catalog_load = make_bytes(EntryKind::CatalogLoad);

    assert_ne!(cc_inference, cc_model_load);
    assert_ne!(cc_inference, cc_catalog_load);
    assert_ne!(cc_model_load, cc_catalog_load);
}

// ---------------------------------------------------------------------------
// §5. Chain reset semantics (audit A6 closure)
//
// chain_reset_reason annotates WHY this envelope follows a discontinuity
// (e.g., catalog hot-swap); the cryptographic chain remains continuous.
// The reset reason is metadata — the chain is NOT forked. Envelope B's
// chain_prev is A.chain_curr, and envelope C's chain_prev is B.chain_curr,
// regardless of chain_reset_reason values.
// ---------------------------------------------------------------------------

#[test]
fn test_chain_reset_reason_does_not_fork_cryptographic_chain() {
    // Envelope A: normal inference.
    let bytes_a = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0xD0),
        fixture_hash(0xD1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_a, chain_curr_a) = verify(bytes_a, zeros32()).unwrap();

    // Envelope B: catalog_changed annotated, but chain_prev is A's chain_curr.
    let bytes_b = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        fixture_hash(0xFF),  // new catalog hash post-swap
        fixture_hash(0xE0),
        fixture_hash(0xE1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 1,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_a,       // continuous — chain NOT broken
        chain_reset_reason = ChainResetReason::CatalogChanged,
    );
    let (env_b, chain_curr_b) = verify(bytes_b, chain_curr_a).unwrap();
    // Chain is unbroken: B.chain_prev == A.chain_curr.
    assert_eq!(env_b.chain_prev, chain_curr_a);
    assert_eq!(env_b.chain_reset_reason, ChainResetReason::CatalogChanged as u16);

    // Envelope C: normal continuation; chain_prev is B.chain_curr.
    let bytes_c = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        fixture_hash(0xFF),  // same new catalog
        fixture_hash(0xF0),
        fixture_hash(0xF1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 2,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_b,
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env_c, _chain_curr_c) = verify(bytes_c, chain_curr_b).unwrap();
    assert_eq!(env_c.chain_prev, chain_curr_b);
}

