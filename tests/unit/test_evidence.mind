// Attestation envelope v2 + chain integrity. Audit A4 (binding completeness), A5 (entry_kind), A6 (chain_reset_reason).
//
// RED TEST FILE — all tests FAIL against the current v1 stub in src/evidence.mind.
//
// Proposed v2 layout (212 bytes, packed):
//
//   offset  size  field
//   0       1     version (= 2)
//   1       1     entry_kind (u8: 1=inference, 2=model_load, 3=catalog_load)
//   2       2     wire_version (u16, little-endian)
//   4       4     k (u32, top-K parameter — audit A4)
//   8       8     timestamp_ms (i64, monotonic)
//   16      1     architecture (u8: 1=x86_64, 2=aarch64, 3=cuda)
//   17      1     reserved (must be 0)
//   18      2     chain_reset_reason (u16: 0=continuation, 1=model_swap,
//                                      2=catalog_changed, 3=clock_reset)
//   20      32    model_hash (SHA-256)
//   52      32    tokenizer_hash (SHA-256 — audit A4)
//   84      32    catalog_hash (SHA-256)
//   116     32    request_hash (SHA-256)
//   148     32    result_hash (SHA-256)
//   180     32    chain_prev (SHA-256 of prior envelope, or zeros if chain start)
//   TOTAL: 212 bytes
//
// chain_curr = SHA-256(all 212 envelope bytes); computed at verify time, never stored.
//
// Alignment note: all multi-byte fields happen to be naturally aligned within
// the packed layout (u16 at even offset, u32 at offset 4, i64 at offset 8).
// @[layout(Packed)] is still required to prevent any compiler-inserted padding.
//
// Architecture enum mapping (v2, 1-based to distinguish 0=uninitialised):
//   1 = x86_64
//   2 = aarch64
//   3 = cuda
//
// (v1 used 0-based; v2 resets the numbering. v1 envelopes are rejected at verify.)

use crate::mind_nerve::evidence::{
    AttestationEnvelope,
    AttestationEnvelopeV2,
    EntryKind,
    Architecture,
    ChainResetReason,
    VerificationOutcome,
    VerificationError,
    emit,
    verify,
    ATTESTATION_V2_SIZE,
    ATTESTATION_V2_VERSION,
};
use crate::mind_nerve::testing::{
    sha256,
    zeros32,
    fixture_hash,
};

// ---------------------------------------------------------------------------
// Shared test fixtures
// ---------------------------------------------------------------------------
//
// All PLACEHOLDER_HASH_* values are 32-byte arrays of a repeating sentinel
// byte. Impl agent: replace with real SHA-256 of representative payloads
// after the first green run.

const PLACEHOLDER_HASH_MODEL:     [u8; 32] = [0x01u8; 32];
const PLACEHOLDER_HASH_TOKENIZER: [u8; 32] = [0x02u8; 32];
const PLACEHOLDER_HASH_CATALOG:   [u8; 32] = [0x03u8; 32];
const PLACEHOLDER_HASH_REQUEST:   [u8; 32] = [0x04u8; 32];
const PLACEHOLDER_HASH_RESULT:    [u8; 32] = [0x05u8; 32];

const DEFAULT_K:            u32 = 5;
const DEFAULT_WIRE_VERSION: u16 = 1;
const DEFAULT_ARCH:         u8  = 1;  // x86_64
const DEFAULT_TIMESTAMP:    i64 = 1_000_000;  // arbitrary monotonic tick

// ---------------------------------------------------------------------------
// §1. Layout assertions
// ---------------------------------------------------------------------------

// Struct size is exactly 212 bytes; any padding would be a spec violation.
#[test]
fn test_envelope_size_is_212_bytes() {
    static_assert!(ATTESTATION_V2_SIZE == 212);
    assert_eq!(size_of::<AttestationEnvelopeV2>(), 212);
}

// The Packed annotation must be present; without it the compiler may insert
// padding between fields and silently change the wire format.
#[test]
#[lint(requires = "@[layout(Packed)]")]
fn test_envelope_has_packed_layout_annotation() {
    assert_layout_annotation!(AttestationEnvelopeV2, Packed);
}

// Verify every field starts at the offset documented in the header comment.
// These tests are the ground-truth contract for the impl agent.

#[test]
fn test_envelope_offset_version_is_0() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, version), 0);
}

#[test]
fn test_envelope_offset_entry_kind_is_1() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, entry_kind), 1);
}

#[test]
fn test_envelope_offset_wire_version_is_2() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, wire_version), 2);
}

#[test]
fn test_envelope_offset_k_is_4() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, k), 4);
}

#[test]
fn test_envelope_offset_timestamp_ms_is_8() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, timestamp_ms), 8);
}

#[test]
fn test_envelope_offset_architecture_is_16() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, architecture), 16);
}

#[test]
fn test_envelope_offset_reserved_is_17() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, reserved), 17);
}

#[test]
fn test_envelope_offset_chain_reset_reason_is_18() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, chain_reset_reason), 18);
}

#[test]
fn test_envelope_offset_model_hash_is_20() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, model_hash), 20);
}

#[test]
fn test_envelope_offset_tokenizer_hash_is_52() {
    // tokenizer_hash was absent in v1; this offset is the load-bearing
    // change that closes audit A4 (binding completeness).
    assert_eq!(offset_of!(AttestationEnvelopeV2, tokenizer_hash), 52);
}

#[test]
fn test_envelope_offset_catalog_hash_is_84() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, catalog_hash), 84);
}

#[test]
fn test_envelope_offset_request_hash_is_116() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, request_hash), 116);
}

#[test]
fn test_envelope_offset_result_hash_is_148() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, result_hash), 148);
}

#[test]
fn test_envelope_offset_chain_prev_is_180() {
    assert_eq!(offset_of!(AttestationEnvelopeV2, chain_prev), 180);
}

// ---------------------------------------------------------------------------
// §2. Emit / round-trip
// ---------------------------------------------------------------------------

// emit() returns a 212-byte packed envelope; verify() parses it and returns
// the struct plus the computed chain_curr.

#[test]
fn test_envelope_emit_produces_212_byte_payload() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert_eq!(bytes.len(), 212);
}

// Round-trip: emit then verify; every caller-supplied field must survive.
#[test]
fn test_envelope_round_trip_fields_preserved() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env, _chain_curr) = verify(bytes, zeros32()).unwrap();

    assert_eq!(env.version,            ATTESTATION_V2_VERSION);
    assert_eq!(env.entry_kind,         EntryKind::Inference as u8);
    assert_eq!(env.wire_version,       DEFAULT_WIRE_VERSION);
    assert_eq!(env.k,                  DEFAULT_K);
    assert_eq!(env.timestamp_ms,       DEFAULT_TIMESTAMP);
    assert_eq!(env.architecture,       DEFAULT_ARCH);
    assert_eq!(env.reserved,           0u8);
    assert_eq!(env.chain_reset_reason, ChainResetReason::Continuation as u16);
    assert_eq!(env.model_hash,         PLACEHOLDER_HASH_MODEL);
    assert_eq!(env.tokenizer_hash,     PLACEHOLDER_HASH_TOKENIZER);
    assert_eq!(env.catalog_hash,       PLACEHOLDER_HASH_CATALOG);
    assert_eq!(env.request_hash,       PLACEHOLDER_HASH_REQUEST);
    assert_eq!(env.result_hash,        PLACEHOLDER_HASH_RESULT);
    assert_eq!(env.chain_prev,         zeros32());
}

// verify() must return the envelope bytes' SHA-256 as chain_curr.
#[test]
fn test_envelope_verify_returns_sha256_of_bytes_as_chain_curr() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let expected_chain_curr = sha256(&bytes);
    let (_env, chain_curr) = verify(bytes, zeros32()).unwrap();
    assert_eq!(chain_curr, expected_chain_curr);
}

// ---------------------------------------------------------------------------
// §3. Chain integrity
// ---------------------------------------------------------------------------

// First envelope in any chain has chain_prev = [0; 32] (chain start sentinel).
#[test]
fn test_chain_first_envelope_has_zero_chain_prev() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env, _) = verify(bytes, zeros32()).unwrap();
    assert_eq!(env.chain_prev, zeros32());
}

// Each subsequent envelope's chain_prev must equal the SHA-256 of the
// immediately preceding envelope. Build a 3-link chain and verify every link.
#[test]
fn test_chain_three_link_chain_prev_references_are_correct() {
    // Link 1
    let bytes_1 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0x10),
        fixture_hash(0x11),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_1, chain_curr_1) = verify(bytes_1, zeros32()).unwrap();

    // Link 2: chain_prev is chain_curr of link 1.
    let bytes_2 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0x20),
        fixture_hash(0x21),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 1,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_1,
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env_2, chain_curr_2) = verify(bytes_2, chain_curr_1).unwrap();
    assert_eq!(env_2.chain_prev, chain_curr_1);

    // Link 3: chain_prev is chain_curr of link 2.
    let bytes_3 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0x30),
        fixture_hash(0x31),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 2,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_2,
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (env_3, _chain_curr_3) = verify(bytes_3, chain_curr_2).unwrap();
    assert_eq!(env_3.chain_prev, chain_curr_2);
}

// Tamper test: flip one bit in link 2. Verify of link 3 (which embeds
// chain_curr_2 as chain_prev) must fail with ChainBroken.
#[test]
fn test_chain_tampered_middle_envelope_breaks_next_link() {
    // Build a valid 3-link chain first.
    let bytes_1 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0xA0),
        fixture_hash(0xA1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_1, chain_curr_1) = verify(bytes_1, zeros32()).unwrap();

    let bytes_2_original = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0xB0),
        fixture_hash(0xB1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 1,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_1,
        chain_reset_reason = ChainResetReason::Continuation,
    );
    let (_env_2, chain_curr_2_original) = verify(bytes_2_original, chain_curr_1).unwrap();

    // Tamper: flip the low bit of the first byte of link 2's request_hash
    // (offset 116 in the 212-byte envelope).
    let mut bytes_2_tampered = bytes_2_original.clone();
    bytes_2_tampered[116] ^= 0x01u8;

    // chain_curr of the tampered envelope differs from the original.
    let chain_curr_2_tampered = sha256(&bytes_2_tampered);
    assert_ne!(chain_curr_2_tampered, chain_curr_2_original);

    // Link 3 was emitted with the ORIGINAL chain_curr_2. When we try to
    // verify it against the tampered chain_curr, verify must reject.
    let bytes_3 = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        fixture_hash(0xC0),
        fixture_hash(0xC1),
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP + 2,
        entry_kind    = EntryKind::Inference,
        chain_prev    = chain_curr_2_original,
        chain_reset_reason = ChainResetReason::Continuation,
    );

    // Pass the tampered chain_curr as the expected predecessor — must fail.
    let result = verify(bytes_3, chain_curr_2_tampered);
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::ChainBroken);
}

