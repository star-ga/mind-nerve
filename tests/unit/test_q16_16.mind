// Q16.16 kernel primitives — bit-identity contract. Audit S-A2 (reduction-order discipline).
//
// RED test file. All tests in this file are expected to FAIL until `src/q16_16.mind`
// is implemented. Running `mindc test tests/unit/test_q16_16.mind` against the
// current state of the repo (no q16_16.mind, unimplemented!() bodies in model.mind)
// must produce "function not implemented" or "module not found" errors for every
// #[test] item. That failure is the signal that the TDD cycle is beginning correctly.
//
// Audit marker: S-A2 (reduction-order discipline) — every reduction in this file
// is documented as either Pinned-Sequential or explicitly Non-equivariant by design.

// PROPOSED CONSTANTS TO ADD TO lib.mind:
//
//   // Q16.16 representation of 1.0: 1 << 16 = 65536
//   pub const ONE_Q16_16:  Q16_16 = 65536_i32;
//
//   // Q16.16 maximum value: i32::MAX = 2147483647
//   pub const MAX_Q16_16:  Q16_16 = 2147483647_i32;
//
//   // Q16.16 minimum value: i32::MIN = -2147483648
//   pub const MIN_Q16_16:  Q16_16 = -2147483648_i32;
//
//   // Q16.16 representation of -1.0: -(1 << 16) = -65536
//   pub const NEG_ONE_Q16_16: Q16_16 = -65536_i32;
//
//   // Q16.16 representation of 0.5: 1 << 15 = 32768
//   pub const HALF_Q16_16: Q16_16 = 32768_i32;
//
//   // Q16.16 representation of 0.25: 1 << 14 = 16384
//   pub const QUARTER_Q16_16: Q16_16 = 16384_i32;
//
//   // Q16.16 representation of 3.0: 3 << 16 = 196608
//   pub const THREE_Q16_16: Q16_16 = 196608_i32;
//
//   // Q16.16 representation of -3.0: -(3 << 16) = -196608
//   pub const NEG_THREE_Q16_16: Q16_16 = -196608_i32;
//
//   // 1 ULP in Q16.16 format: 1
//   pub const ULP_Q16_16: Q16_16 = 1_i32;
//
// These constants MUST be added to src/lib.mind before src/q16_16.mind can be
// compiled. The tests below reference them by name; the symbols are declared here
// as comments only so the intent is explicit at the RED stage.

use crate::mind_nerve::q16_16::{
    q16_mul,
    q16_add,
    q16_dot,
    q16_softmax,
    q16_layernorm,
    q16_sat_cast,
    q16_widen,
    sha256_bytes,    // intrinsic: SHA-256 of a byte slice; used for determinism oracles
};

use crate::mind_nerve::{
    Q16_16,
    ONE_Q16_16,
    MAX_Q16_16,
    MIN_Q16_16,
    NEG_ONE_Q16_16,
    HALF_Q16_16,
    QUARTER_Q16_16,
    THREE_Q16_16,
    NEG_THREE_Q16_16,
    ULP_Q16_16,
};

// ─────────────────────────────────────────────────────────────────────────────
// Helpers used across test groups. Not exported; test-only.
// ─────────────────────────────────────────────────────────────────────────────

// Encode a raw i32 as a Q16.16 canonical byte array (little-endian), then
// SHA-256 it. Used in determinism oracle tests.
fn sha256_q16(v: Q16_16) -> [u8; 32] {
    sha256_bytes(&v.to_le_bytes())
}

// SHA-256 of a Q16.16 slice, in element order. Concatenate le_bytes of each
// element, then hash the concatenation. Pinned to left-to-right element order.
fn sha256_q16_slice(vs: &[Q16_16]) -> [u8; 32] {
    let mut buf: [u8] = [];
    for v in vs {
        buf.extend(v.to_le_bytes());
    }
    sha256_bytes(&buf)
}

// Linear-congruential generator seeded with a u64. Returns the next value and
// the updated state. Used to generate reproducible but varied test inputs
// without depending on a runtime RNG.
fn lcg_next(state: u64) -> (u64, i32) {
    // Multiplier and addend from Knuth TAOCP Vol 2 §3.3.4 (generic well-known params).
    let next = state.wrapping_mul(6364136223846793005_u64).wrapping_add(1442695040888963407_u64);
    // Fold 64 bits to i32 by xor-folding upper and lower halves.
    let folded = ((next >> 32) as i32) ^ (next as i32);
    (next, folded)
}

// ─────────────────────────────────────────────────────────────────────────────
// Section 1: q16_mul — multiply with saturation, toward-zero rounding
// ─────────────────────────────────────────────────────────────────────────────

#[test]
fn test_q16_mul_identity_positive_three() {
    // Invariant: multiplying by ONE (1.0 in Q16.16) is the identity for any value.
    assert_eq!(q16_mul(ONE_Q16_16, THREE_Q16_16), THREE_Q16_16);
}

#[test]
fn test_q16_mul_identity_negative_three() {
    // Invariant: multiplying by ONE (1.0 in Q16.16) is the identity for any value.
    assert_eq!(q16_mul(ONE_Q16_16, NEG_THREE_Q16_16), NEG_THREE_Q16_16);
}

#[test]
fn test_q16_mul_identity_positive_one() {
    // Invariant: multiplying by ONE is the identity for 1.0.
    assert_eq!(q16_mul(ONE_Q16_16, ONE_Q16_16), ONE_Q16_16);
}

#[test]
fn test_q16_mul_identity_negative_one() {
    // Invariant: multiplying by ONE is the identity for -1.0.
    assert_eq!(q16_mul(ONE_Q16_16, NEG_ONE_Q16_16), NEG_ONE_Q16_16);
}

#[test]
fn test_q16_mul_identity_zero() {
    // Invariant: multiplying by ONE is the identity for 0.
    assert_eq!(q16_mul(ONE_Q16_16, 0_i32), 0_i32);
}

#[test]
fn test_q16_mul_zero_left_positive() {
    // Invariant: zero times any value is zero (left multiplicand = 0).
    assert_eq!(q16_mul(0_i32, THREE_Q16_16), 0_i32);
}

#[test]
fn test_q16_mul_zero_left_negative() {
    // Invariant: zero times any value is zero (left multiplicand = 0, negative right).
    assert_eq!(q16_mul(0_i32, NEG_THREE_Q16_16), 0_i32);
}

#[test]
fn test_q16_mul_zero_right_positive() {
    // Invariant: any value times zero is zero (right multiplicand = 0).
    assert_eq!(q16_mul(THREE_Q16_16, 0_i32), 0_i32);
}

#[test]
fn test_q16_mul_zero_right_min() {
    // Invariant: MIN_Q16_16 times zero is zero (boundary zero-arm test).
    assert_eq!(q16_mul(MIN_Q16_16, 0_i32), 0_i32);
}

#[test]
fn test_q16_mul_commutativity_seeded() {
    // Invariant: q16_mul is commutative — q16_mul(a,b) == q16_mul(b,a) for all
    // non-saturating inputs (the 20 seeds below are chosen so neither product overflows).
    // Seeds produce values in the range [-8.0, 8.0] Q16.16 (i.e. |x| <= 8*ONE_Q16_16).
    let seeds: [u64; 20] = [
        0x0001_0000_0001_0000,  // seed 0
        0x0002_0000_0002_0000,  // seed 1
        0x8FFF_1234_ABCD_EF01,  // seed 2
        0x1111_2222_3333_4444,  // seed 3
        0xDEAD_BEEF_CAFE_BABE,  // seed 4
        0x0123_4567_89AB_CDEF,  // seed 5
        0xFEDC_BA98_7654_3210,  // seed 6
        0x0000_0000_0000_0001,  // seed 7
        0x7FFF_FFFF_FFFF_FFFE,  // seed 8 (large positive, clamp range)
        0x4000_0000_0000_0000,  // seed 9
        0x3141_5926_5358_9793,  // seed 10 (pi-ish bits)
        0x2718_2818_2845_9045,  // seed 11 (e-ish bits)
        0xAAAA_AAAA_AAAA_AAAA,  // seed 12 (alternating bits)
        0x5555_5555_5555_5555,  // seed 13 (alternating bits inverse)
        0x0000_0000_FFFF_FFFF,  // seed 14
        0xFFFF_FFFF_0000_0000,  // seed 15
        0x0F0F_0F0F_0F0F_0F0F,  // seed 16
        0xF0F0_F0F0_F0F0_F0F0,  // seed 17
        0x1234_5678_9ABC_DEF0,  // seed 18
        0xABCD_EF01_2345_6789,  // seed 19
    ];
    for seed in seeds {
        let (s1, raw_a) = lcg_next(seed);
        let (_s2, raw_b) = lcg_next(s1);
        // Scale to [-4.0, 4.0] to stay comfortably within non-saturating range.
        // Mask to 17 bits (range 0..131071) then shift to signed center.
        let a: Q16_16 = ((raw_a & 0x0001_FFFF_i32).wrapping_sub(65536_i32)).wrapping_mul(4_i32);
        let b: Q16_16 = ((raw_b & 0x0001_FFFF_i32).wrapping_sub(65536_i32)).wrapping_mul(4_i32);
        assert_eq!(
            q16_mul(a, b),
            q16_mul(b, a),
            "commutativity failed for seed=0x{:016X}: a={} b={}", seed, a, b
        );
    }
}

#[test]
fn test_q16_mul_saturation_positive_overflow() {
    // Invariant: multiplying two values that would overflow must clamp to MAX_Q16_16.
    // MAX_Q16_16 * MAX_Q16_16 in full precision is >> MAX_Q16_16, must saturate.
    assert_eq!(q16_mul(MAX_Q16_16, MAX_Q16_16), MAX_Q16_16);
}

#[test]
fn test_q16_mul_saturation_negative_overflow() {
    // Invariant: MIN * MAX in full precision is << MIN_Q16_16; must clamp to MIN_Q16_16.
    assert_eq!(q16_mul(MIN_Q16_16, MAX_Q16_16), MIN_Q16_16);
}

#[test]
fn test_q16_mul_saturation_min_times_min() {
    // Invariant: MIN * MIN would be large positive — must clamp to MAX_Q16_16.
    // (Two negatives multiply to positive; the magnitude overflows i32 representable range.)
    assert_eq!(q16_mul(MIN_Q16_16, MIN_Q16_16), MAX_Q16_16);
}

#[test]
fn test_q16_mul_rounding_half_times_half() {
    // Invariant: 0.5 * 0.5 = 0.25 exactly in Q16.16 with toward-zero rounding.
    // HALF_Q16_16 = 32768, QUARTER_Q16_16 = 16384.
    // Full precision product: 32768 * 32768 = 1073741824; shift right 16 = 16384 exactly.
    // No rounding ambiguity at this input; result is bit-exact.
    assert_eq!(q16_mul(HALF_Q16_16, HALF_Q16_16), QUARTER_Q16_16);
}

#[test]
fn test_q16_mul_rounding_toward_zero_not_banker() {
    // Invariant: rounding mode is toward-zero, NOT banker's (round-half-to-even).
    //
    // Construct a product whose fractional bits are exactly 0x8000 (i.e. midpoint = 0.5 ULP).
    // Toward-zero rounding: truncate fractional bits → result rounds toward zero.
    // Banker's rounding: would round to the nearest even integer → different bit.
    //
    // Input pair: a = 3 * ONE_Q16_16 + HALF_Q16_16 = 229376  (3.5 in Q16.16)
    //             b = ONE_Q16_16                    = 65536   (1.0 in Q16.16)
    // Full product: 229376 * 65536 = 15032385536. Shift right 16: 229376 exactly.
    // No mid-point here — use a case that exercises the 0x8000 fractional boundary.
    //
    // Better pair: a = 65537 (= ONE + 1 ULP), b = 32768 (= HALF).
    // Full product: 65537 * 32768 = 2147516416. Shift right 16 = 32768 remainder 32768.
    // Toward-zero: 32768 (HALF_Q16_16). Banker's: 32768 (even — same here).
    //
    // Use a case where the two modes diverge: a = 3 ULP, b = HALF.
    // Full product: 3 * 32768 = 98304. Shift right 16 = 1 remainder 32768 (exact 0.5 ULP).
    // Toward-zero: 1. Banker's (round-half-to-even): 2 (since 1 is odd, round up to 2).
    // So: q16_mul(3, HALF_Q16_16) must equal 1, NOT 2.
    assert_eq!(q16_mul(3_i32, HALF_Q16_16), 1_i32);
}

#[test]
fn test_q16_mul_determinism_oracle() {
    // Invariant: fixed inputs always produce the same byte-level output across
    // architectures and runs. The SHA-256 of the canonical little-endian i32
    // representation is compared to a hardcoded expected digest.
    // TODO(P1.1.2): replace PLACEHOLDER_HASH_MUL after first green run.
    let result = q16_mul(THREE_Q16_16, HALF_Q16_16);   // 3.0 * 0.5 = 1.5 expected
    let digest = sha256_q16(result);
    let expected: [u8; 32] = *b"PLACEHOLDER_HASH_MUL____________"; // 32 bytes
    assert_eq!(digest, expected, "q16_mul determinism oracle failed");
}

