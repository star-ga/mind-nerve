    __mind_store_i64(rsqrt_buf + 16168, 4122);
    __mind_store_i64(rsqrt_buf + 16176, 4121);
    __mind_store_i64(rsqrt_buf + 16184, 4120);
    __mind_store_i64(rsqrt_buf + 16192, 4119);
    __mind_store_i64(rsqrt_buf + 16200, 4118);
    __mind_store_i64(rsqrt_buf + 16208, 4117);
    __mind_store_i64(rsqrt_buf + 16216, 4116);
    __mind_store_i64(rsqrt_buf + 16224, 4115);
    __mind_store_i64(rsqrt_buf + 16232, 4114);
    __mind_store_i64(rsqrt_buf + 16240, 4113);
    __mind_store_i64(rsqrt_buf + 16248, 4112);
    __mind_store_i64(rsqrt_buf + 16256, 4111);
    __mind_store_i64(rsqrt_buf + 16264, 4110);
    __mind_store_i64(rsqrt_buf + 16272, 4109);
    __mind_store_i64(rsqrt_buf + 16280, 4108);
    __mind_store_i64(rsqrt_buf + 16288, 4107);
    __mind_store_i64(rsqrt_buf + 16296, 4106);
    __mind_store_i64(rsqrt_buf + 16304, 4105);
    __mind_store_i64(rsqrt_buf + 16312, 4104);
    __mind_store_i64(rsqrt_buf + 16320, 4103);
    __mind_store_i64(rsqrt_buf + 16328, 4102);
