// SHA-256 byte-exact contract. Audit hash-chain integrity (FP-9, S-5).
//
// All tests in this file target `inference::sha256(input: [u8]) -> [u8; 32]`.
// Every test is RED against the current unimplemented!() stub.
// Run-to-green requires a complete RFC 6234-compliant SHA-256 implementation.
//
// Usage: the three call-sites in mind-nerve are:
//   (1) catalog hash binding: SHA-256(canonical-serialization) in RouteCatalog
//   (2) top-K tie-break:      SHA-256(route_id) ascending comparison
//   (3) attestation chain:    chain_curr = SHA-256(envelope fields || chain_prev)
//
// This file exercises the primitive independently of those call-sites so that
// any failure is isolated to the SHA-256 implementation, not to the callers.

use crate::mind_nerve::inference::sha256;

// ---------------------------------------------------------------------------
// Section 1: RFC 6234 test vectors (bit-exact)
// ---------------------------------------------------------------------------
// Five vectors from RFC 6234 / FIPS 180-4.  These are the load-bearing
// inter-operability anchors; any correct SHA-256 must produce these outputs.

#[test]
fn test_sha256_rfc6234_empty_string() {
    // Property: SHA-256 of the empty byte sequence is the known constant.
    let got = sha256(b"");
    let want: [u8; 32] = [
        0xE3, 0xB0, 0xC4, 0x42, 0x98, 0xFC, 0x1C, 0x14,
        0x9A, 0xFB, 0xF4, 0xC8, 0x99, 0x6F, 0xB9, 0x24,
        0x27, 0xAE, 0x41, 0xE4, 0x64, 0x9B, 0x93, 0x4C,
        0xA4, 0x95, 0x99, 0x1B, 0x78, 0x52, 0xB8, 0x55,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_rfc6234_abc() {
    // Property: SHA-256("abc") matches the RFC 6234 §B.1 vector.
    let got = sha256(b"abc");
    let want: [u8; 32] = [
        0xBA, 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA,
        0x41, 0x41, 0x40, 0xDE, 0x5D, 0xAE, 0x22, 0x23,
        0xB0, 0x03, 0x61, 0xA3, 0x96, 0x17, 0x7A, 0x9C,
        0xB4, 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_rfc6234_448bit_message() {
    // Property: SHA-256 of the 56-char message from RFC 6234 §B.2 (two-block input).
    let input = b"abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq";
    let got = sha256(input);
    let want: [u8; 32] = [
        0x24, 0x8D, 0x6A, 0x61, 0xD2, 0x06, 0x38, 0xB8,
        0xE5, 0xC0, 0x26, 0x93, 0x0C, 0x3E, 0x60, 0x39,
        0xA3, 0x3C, 0xE4, 0x59, 0x64, 0xFF, 0x21, 0x67,
        0xF6, 0xEC, 0xED, 0xD4, 0x19, 0xDB, 0x06, 0xC1,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_rfc6234_one_million_a() {
    // Property: SHA-256 of 1,000,000 repetitions of 'a' (RFC 6234 §B.3).
    // This tests multi-block processing across many full blocks.
    let input: [u8] = [b'a'; 1_000_000];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0xCD, 0xC7, 0x6E, 0x5C, 0x99, 0x14, 0xFB, 0x92,
        0x81, 0xA1, 0xC7, 0xE2, 0x84, 0xD7, 0x3E, 0x67,
        0xF1, 0x80, 0x9A, 0x48, 0xA4, 0x97, 0x20, 0x0E,
        0x04, 0x6D, 0x39, 0xCC, 0xC7, 0x11, 0x2C, 0xD0,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_rfc6234_quick_brown_fox() {
    // Property: SHA-256 of the common pangram matches the well-known value.
    let input = b"The quick brown fox jumps over the lazy dog";
    let got = sha256(input);
    let want: [u8; 32] = [
        0xD7, 0xA8, 0xFB, 0xB3, 0x07, 0xD7, 0x80, 0x94,
        0x69, 0xCA, 0x9A, 0xBC, 0xB0, 0x08, 0x2E, 0x4F,
        0x8D, 0x56, 0x51, 0xE4, 0x6D, 0x3C, 0xDB, 0x76,
        0x2D, 0x02, 0xD0, 0xBF, 0x37, 0xC9, 0xE5, 0x92,
    ];
    assert_eq!(got, want);
}

// ---------------------------------------------------------------------------
// Section 2: Boundary length cases
// ---------------------------------------------------------------------------
// These inputs probe SHA-256 padding arithmetic at the edges of block
// boundaries (512-bit / 64-byte blocks).  Each expected value was computed
// with Python 3 hashlib.sha256; input bytes are `bytes(range(n))` for length n.

#[test]
fn test_sha256_boundary_0_bytes() {
    // Property: zero-length input → known constant (same as RFC vector above).
    let got = sha256(b"");
    let want: [u8; 32] = [
        0xE3, 0xB0, 0xC4, 0x42, 0x98, 0xFC, 0x1C, 0x14,
        0x9A, 0xFB, 0xF4, 0xC8, 0x99, 0x6F, 0xB9, 0x24,
        0x27, 0xAE, 0x41, 0xE4, 0x64, 0x9B, 0x93, 0x4C,
        0xA4, 0x95, 0x99, 0x1B, 0x78, 0x52, 0xB8, 0x55,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_1_byte_null() {
    // Property: single 0x00 byte → correct digest (single-byte edge case).
    let got = sha256(&[0x00u8]);
    let want: [u8; 32] = [
        0x6E, 0x34, 0x0B, 0x9C, 0xFF, 0xB3, 0x7A, 0x98,
        0x9C, 0xA5, 0x44, 0xE6, 0xBB, 0x78, 0x0A, 0x2C,
        0x78, 0x90, 0x1D, 0x3F, 0xB3, 0x37, 0x38, 0x76,
        0x85, 0x11, 0xA3, 0x06, 0x17, 0xAF, 0xA0, 0x1D,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_55_bytes() {
    // Property: 55 bytes is the last length that fits with padding in one block.
    // Input: bytes 0x00..0x36 (55 bytes sequential).
    let input: [u8; 55] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0x46, 0x3E, 0xB2, 0x8E, 0x72, 0xF8, 0x2E, 0x0A,
        0x96, 0xC0, 0xA4, 0xCC, 0x53, 0x69, 0x0C, 0x57,
        0x12, 0x81, 0x13, 0x1F, 0x67, 0x2A, 0xA2, 0x29,
        0xE0, 0xD4, 0x5A, 0xE5, 0x9B, 0x59, 0x8B, 0x59,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_56_bytes() {
    // Property: 56 bytes forces a second padding block (first length that does).
    // Input: bytes 0x00..0x37 (56 bytes sequential).
    let input: [u8; 56] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36, 0x37,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0xDA, 0x2A, 0xE4, 0xD6, 0xB3, 0x67, 0x48, 0xF2,
        0xA3, 0x18, 0xF2, 0x3E, 0x7A, 0xB1, 0xDF, 0xDF,
        0x45, 0xAC, 0xDC, 0x9D, 0x04, 0x9B, 0xD8, 0x0E,
        0x59, 0xDE, 0x82, 0xA6, 0x08, 0x95, 0xF5, 0x62,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_64_bytes() {
    // Property: exactly one 512-bit SHA-256 block → correct digest.
    // Input: bytes 0x00..0x3F (64 bytes sequential).
    let input: [u8; 64] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36, 0x37,
        0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0xFD, 0xEA, 0xB9, 0xAC, 0xF3, 0x71, 0x03, 0x62,
        0xBD, 0x26, 0x58, 0xCD, 0xC9, 0xA2, 0x9E, 0x8F,
        0x9C, 0x75, 0x7F, 0xCF, 0x98, 0x11, 0x60, 0x3A,
        0x8C, 0x44, 0x7C, 0xD1, 0xD9, 0x15, 0x11, 0x08,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_65_bytes() {
    // Property: one full block plus one carry byte → correct digest.
    // Input: bytes 0x00..0x40 (65 bytes sequential).
    let input: [u8; 65] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36, 0x37,
        0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F,
        0x40,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0x4B, 0xFD, 0x2C, 0x8B, 0x6F, 0x1E, 0xEC, 0x7A,
        0x2A, 0xFE, 0xB4, 0x8B, 0x93, 0x4E, 0xE4, 0xB2,
        0x69, 0x41, 0x82, 0x02, 0x7E, 0x6D, 0x0F, 0xC0,
        0x75, 0x07, 0x4F, 0x2F, 0xAB, 0xB3, 0x17, 0x81,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_127_bytes() {
    // Property: 127 bytes = last input before the two-block padding pair ends at 128.
    // Input: bytes 0x00..0x7E (127 bytes sequential).
    let input: [u8; 127] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36, 0x37,
        0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F,
        0x40, 0x41, 0x42, 0x43, 0x44, 0x45, 0x46, 0x47,
        0x48, 0x49, 0x4A, 0x4B, 0x4C, 0x4D, 0x4E, 0x4F,
        0x50, 0x51, 0x52, 0x53, 0x54, 0x55, 0x56, 0x57,
        0x58, 0x59, 0x5A, 0x5B, 0x5C, 0x5D, 0x5E, 0x5F,
        0x60, 0x61, 0x62, 0x63, 0x64, 0x65, 0x66, 0x67,
        0x68, 0x69, 0x6A, 0x6B, 0x6C, 0x6D, 0x6E, 0x6F,
        0x70, 0x71, 0x72, 0x73, 0x74, 0x75, 0x76, 0x77,
        0x78, 0x79, 0x7A, 0x7B, 0x7C, 0x7D, 0x7E,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0x92, 0xCA, 0x0F, 0xA6, 0x65, 0x1E, 0xE2, 0xF9,
        0x7B, 0x88, 0x4B, 0x72, 0x46, 0xA5, 0x62, 0xFA,
        0x71, 0x25, 0x0F, 0xED, 0xEF, 0xE5, 0xEB, 0xF2,
        0x70, 0xD3, 0x1C, 0x54, 0x6B, 0xFE, 0xA9, 0x76,
    ];
    assert_eq!(got, want);
}

#[test]
fn test_sha256_boundary_128_bytes() {
    // Property: exactly two 512-bit SHA-256 blocks (padding goes into a third).
    // Input: bytes 0x00..0x7F (128 bytes sequential).
    let input: [u8; 128] = [
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F,
        0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,
        0x18, 0x19, 0x1A, 0x1B, 0x1C, 0x1D, 0x1E, 0x1F,
        0x20, 0x21, 0x22, 0x23, 0x24, 0x25, 0x26, 0x27,
        0x28, 0x29, 0x2A, 0x2B, 0x2C, 0x2D, 0x2E, 0x2F,
        0x30, 0x31, 0x32, 0x33, 0x34, 0x35, 0x36, 0x37,
        0x38, 0x39, 0x3A, 0x3B, 0x3C, 0x3D, 0x3E, 0x3F,
        0x40, 0x41, 0x42, 0x43, 0x44, 0x45, 0x46, 0x47,
        0x48, 0x49, 0x4A, 0x4B, 0x4C, 0x4D, 0x4E, 0x4F,
        0x50, 0x51, 0x52, 0x53, 0x54, 0x55, 0x56, 0x57,
        0x58, 0x59, 0x5A, 0x5B, 0x5C, 0x5D, 0x5E, 0x5F,
        0x60, 0x61, 0x62, 0x63, 0x64, 0x65, 0x66, 0x67,
        0x68, 0x69, 0x6A, 0x6B, 0x6C, 0x6D, 0x6E, 0x6F,
        0x70, 0x71, 0x72, 0x73, 0x74, 0x75, 0x76, 0x77,
        0x78, 0x79, 0x7A, 0x7B, 0x7C, 0x7D, 0x7E, 0x7F,
    ];
    let got = sha256(&input);
    let want: [u8; 32] = [
        0x47, 0x1F, 0xB9, 0x43, 0xAA, 0x23, 0xC5, 0x11,
        0xF6, 0xF7, 0x2F, 0x8D, 0x16, 0x52, 0xD9, 0xC8,
        0x80, 0xCF, 0xA3, 0x92, 0xAD, 0x80, 0x50, 0x31,
        0x20, 0x54, 0x77, 0x03, 0xE5, 0x6A, 0x2B, 0xE5,
    ];
    assert_eq!(got, want);
}

// ---------------------------------------------------------------------------
// Section 3: Determinism / bit-identity
// ---------------------------------------------------------------------------

#[test]
fn test_sha256_determinism_same_input_same_output() {
    // Property: calling sha256 twice on the same input returns identical bytes.
    // Catches any use of unseeded randomness or mutable global state.
    let input = b"mind-nerve determinism probe 2026-05-13";
    let first  = sha256(input);
    let second = sha256(input);
    assert_eq!(first, second);
}

#[test]
fn test_sha256_determinism_100_fixed_inputs_kernel_hash() {
    // Property: SHA-256 of the concatenation of 100 fixed digests is a known constant.
    // Inputs are 32-byte blobs generated by Python random.Random(0xDEADBEEF).
    // This locks down kernel determinism across any number of calls in a session.
    //
    // Expected overall digest: SHA-256(h[0] || h[1] || ... || h[99])
    //   = 280510dcfae5d79b3803ba5b4255024d9a32268b1474486b9a85a56d56968b26
    //
    // Seed: 0xDEADBEEF, RNG: Python random.Random, 100 × 32 bytes.

    let inputs: [[u8; 32]; 100] = [
        [0x09, 0xDA, 0xF0, 0xDA, 0xC1, 0xEE, 0xA9, 0xCA, 0xBA, 0xD0, 0xC3, 0x89, 0x8D, 0x80, 0x80, 0x5A, 0xA1, 0xC7, 0x45, 0xF9, 0xD2, 0xA2, 0xF2, 0x43, 0x03, 0x4F, 0xC8, 0x5A, 0x98, 0x52, 0xB7, 0xFD],
        [0xAA, 0xE7, 0xC6, 0xE2, 0x84, 0x70, 0x2B, 0xEB, 0xAA, 0xFF, 0x62, 0x05, 0x19, 0x4E, 0x8E, 0xF4, 0xBE, 0xEF, 0x16, 0x45, 0xE2, 0x7A, 0x46, 0x9D, 0x40, 0xE0, 0xC3, 0x52, 0x39, 0xC0, 0x12, 0xA8],
        [0x5B, 0xD5, 0x8D, 0x5D, 0x37, 0x1B, 0xBE, 0xB5, 0x4C, 0x74, 0xFA, 0x37, 0xDB, 0xD6, 0xE0, 0xE9, 0xF2, 0x74, 0xED, 0x03, 0xC4, 0x4F, 0x4F, 0xBA, 0x71, 0xAD, 0x5F, 0xC3, 0x7C, 0x2D, 0xA3, 0xB8],
        [0x1D, 0x37, 0xBF, 0x3F, 0x96, 0xFB, 0x40, 0xF5, 0x12, 0xCE, 0xA7, 0x31, 0x6C, 0x6C, 0xA1, 0xC5, 0xCA, 0xD9, 0xD0, 0x81, 0xCC, 0xF3, 0xBB, 0x8B, 0x58, 0xB5, 0x1E, 0x04, 0x27, 0xD6, 0xFC, 0xF9],
        [0x7E, 0x00, 0xFD, 0xDA, 0xB5, 0xFD, 0x6C, 0x56, 0x8B, 0x59, 0x9D, 0x1D, 0xE8, 0x7F, 0xBD, 0x5B, 0x34, 0x02, 0xD9, 0x16, 0x7C, 0x98, 0xAF, 0xEC, 0xD2, 0xF5, 0x8D, 0x09, 0xA8, 0x9F, 0x2C, 0x10],
        [0xBE, 0x93, 0x7F, 0x4B, 0xFB, 0x5B, 0x90, 0x94, 0xFB, 0x7C, 0x6E, 0xC4, 0x32, 0xFF, 0x4C, 0x3D, 0xF9, 0xBD, 0xFC, 0x0D, 0x11, 0x34, 0xBC, 0xF9, 0x0E, 0x0F, 0x33, 0x47, 0x23, 0xE4, 0x95, 0xC2],
        [0xC7, 0x6F, 0x3D, 0xD5, 0xB2, 0x8B, 0xE6, 0x75, 0xC8, 0x55, 0xC4, 0x75, 0x86, 0xDD, 0x2F, 0x0B, 0xCC, 0x96, 0xD3, 0x1E, 0xDD, 0xB8, 0x95, 0x22, 0x72, 0x82, 0x2F, 0x37, 0x05, 0xDC, 0xA0, 0x0A],
        [0xBE, 0x84, 0xE6, 0x94, 0x5F, 0x49, 0x81, 0x41, 0x08, 0x6D, 0x7E, 0x66, 0xA7, 0x07, 0x5A, 0x54, 0x0A, 0xD8, 0xD8, 0x7D, 0x41, 0x13, 0x03, 0x04, 0x9D, 0x1B, 0xEB, 0xE9, 0x16, 0x8C, 0xBE, 0xB1],
        [0x14, 0xEA, 0x32, 0x2C, 0x13, 0x86, 0xEF, 0x68, 0x31, 0x50, 0x92, 0x18, 0x57, 0x61, 0x1C, 0x44, 0xDD, 0x23, 0x1E, 0x6E, 0x53, 0xAD, 0xEB, 0xB5, 0x5A, 0x73, 0x30, 0x69, 0x0C, 0x7F, 0x57, 0xD2],
        [0x1B, 0xC3, 0x1F, 0xDF, 0x98, 0xFC, 0x5C, 0x5B, 0x54, 0x4E, 0x91, 0x68, 0xCB, 0xFF, 0x42, 0x0C, 0x93, 0xF6, 0x31, 0xFE, 0x76, 0xD7, 0x70, 0x18, 0xE0, 0x46, 0x51, 0x5D, 0x3E, 0xCF, 0x18, 0xED],
