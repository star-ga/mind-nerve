/target/
/build/
*.o
*.so
*.dylib
*.dll
*.exe

# MIND compiler outputs
*.mind-cache/
*.mind-bin
*.mind-ir

# Trained weights — never committed
*.mind-weights
*.safetensors
*.bin

# Evidence chain logs (local, per-host)
*.evidence.log
.mind-nerve/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Python tooling (training pipeline lives outside the inference tree)
__pycache__/
*.pyc
.venv/
venv/

# Node tooling (for TypeScript integrations)
node_modules/
*.tsbuildinfo

# Internal research / audit / planning notes — never published
/research/
/AUDITS/
/.internal/

# autoresearch per-iteration artifacts
/run.log
/autoresearch_results.tsv
/.autoresearch-*.log
/.autoresearch-state/

# Proprietary protection toolchain lives in star-ga/mind-nerve-protected (private).
# This open-source repo MUST NOT contain protection sources or build artefacts.
# History was scrubbed via `git filter-repo --path protected-build --invert-paths`
# on 2026-05-16; this guard prevents the contents from being re-introduced.
protected-build/
protected-build/**
mind-nerve-protected/
dist/
*.so
*.dylib
*.dll

# arch-mind transient state (Tranche 5). Including last_summary.json keeps
# the local absolute repo path out of the public tree.
.arch-mind/store/
.arch-mind/_log_*
.arch-mind/scan_before.json
.arch-mind/last_summary.json

# Python build artifacts
*.egg-info/
python/*.egg-info/

# Private audit reports (Copilot CLI, internal review). Keep local —
# those records quote the very strings they recommend scrubbing.
audits/*-audit.md
audits/*-review.md
audits/*-independent-audit.md

# pytest-cov runtime artifact
.coverage
.coverage.*
htmlcov/
coverage.xml
