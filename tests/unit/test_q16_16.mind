#[test]
fn test_q16_add_identity_positive() {
    // Invariant: adding zero is the identity for a positive value.
    assert_eq!(q16_add(0_i32, THREE_Q16_16), THREE_Q16_16);
}

#[test]
fn test_q16_add_identity_negative() {
    // Invariant: adding zero is the identity for a negative value.
    assert_eq!(q16_add(0_i32, NEG_THREE_Q16_16), NEG_THREE_Q16_16);
}

#[test]
fn test_q16_add_identity_zero() {
    // Invariant: adding zero to zero yields zero.
    assert_eq!(q16_add(0_i32, 0_i32), 0_i32);
}

#[test]
fn test_q16_add_identity_min() {
    // Invariant: adding zero to MIN_Q16_16 preserves MIN_Q16_16 (no wraparound).
    assert_eq!(q16_add(0_i32, MIN_Q16_16), MIN_Q16_16);
}

#[test]
fn test_q16_add_commutativity_seeded() {
    // Invariant: q16_add is commutative for non-saturating inputs.
    // Seeds produce values in [-4.0, 4.0] Q16.16 to avoid overflow.
    let seeds: [u64; 10] = [
        0xAABBCCDD_EEFF0011,
        0x11223344_55667788,
        0x99AABBCC_DDEEFF00,
        0xFEDCBA98_76543210,
        0x01234567_89ABCDEF,
        0xDEADBEEF_DEADBEEF,
        0xCAFEBABE_CAFEBABE,
        0x0F0F0F0F_0F0F0F0F,
        0xF0F0F0F0_F0F0F0F0,
        0x12345678_ABCDEF01,
    ];
    for seed in seeds {
        let (s1, raw_a) = lcg_next(seed);
        let (_s2, raw_b) = lcg_next(s1);
        let a: Q16_16 = (raw_a & 0x0007_FFFF_i32).wrapping_sub(262144_i32);
        let b: Q16_16 = (raw_b & 0x0007_FFFF_i32).wrapping_sub(262144_i32);
        assert_eq!(
            q16_add(a, b),
            q16_add(b, a),
            "commutativity failed for seed=0x{:016X}: a={} b={}", seed, a, b
        );
    }
}

#[test]
fn test_q16_add_associativity_seeded() {
    // Invariant: q16_add is associative for non-saturating inputs:
    // q16_add(q16_add(a, b), c) == q16_add(a, q16_add(b, c)).
    // NOTE: Associativity holds only when no intermediate result saturates.
    // Seeds are designed so |a|, |b|, |c| are each ≤ 2.0 Q16.16.
    let seeds: [u64; 10] = [
        0x1111_1111_1111_1111,
        0x2222_2222_2222_2222,
        0x3333_3333_3333_3333,
        0x4444_4444_4444_4444,
        0x5555_5555_5555_5555,
        0x6666_6666_6666_6666,
        0x7777_7777_7777_7777,
        0x8888_8888_8888_8888,
        0x9999_9999_9999_9999,
        0xAAAA_AAAA_AAAA_AAAA,
    ];
    for seed in seeds {
        let (s1, raw_a) = lcg_next(seed);
        let (s2, raw_b) = lcg_next(s1);
        let (_s3, raw_c) = lcg_next(s2);
        // Clamp to [-2.0, 2.0] so sum of all three stays within [-6.0, 6.0], no saturation.
        let a: Q16_16 = (raw_a & 0x0003_FFFF_i32).wrapping_sub(131072_i32);
        let b: Q16_16 = (raw_b & 0x0003_FFFF_i32).wrapping_sub(131072_i32);
        let c: Q16_16 = (raw_c & 0x0003_FFFF_i32).wrapping_sub(131072_i32);
        let lhs = q16_add(q16_add(a, b), c);
        let rhs = q16_add(a, q16_add(b, c));
        assert_eq!(lhs, rhs,
            "associativity failed for seed=0x{:016X}: a={} b={} c={}", seed, a, b, c
        );
    }
}

#[test]
fn test_q16_add_saturation_positive() {
    // Invariant: MAX + 1 ULP must clamp to MAX_Q16_16, not wrap.
    assert_eq!(q16_add(MAX_Q16_16, ULP_Q16_16), MAX_Q16_16);
}

#[test]
fn test_q16_add_saturation_positive_large() {
    // Invariant: MAX + ONE must also clamp to MAX_Q16_16.
    assert_eq!(q16_add(MAX_Q16_16, ONE_Q16_16), MAX_Q16_16);
}

#[test]
fn test_q16_add_saturation_negative() {
    // Invariant: MIN + (-1 ULP) must clamp to MIN_Q16_16, not wrap.
    assert_eq!(q16_add(MIN_Q16_16, -ULP_Q16_16), MIN_Q16_16);
}

#[test]
fn test_q16_add_saturation_negative_one() {
    // Invariant: MIN + (-ONE) must clamp to MIN_Q16_16.
    assert_eq!(q16_add(MIN_Q16_16, NEG_ONE_Q16_16), MIN_Q16_16);
}

#[test]
fn test_q16_add_cancellation() {
    // Invariant: x + (-x) == 0 for a representative value.
    assert_eq!(q16_add(THREE_Q16_16, NEG_THREE_Q16_16), 0_i32);
}

#[test]
fn test_q16_add_determinism_oracle() {
    // Invariant: fixed inputs always produce the same byte-level output.
    // TODO(P1.1.2): replace PLACEHOLDER_HASH_ADD after first green run.
    let result = q16_add(THREE_Q16_16, NEG_ONE_Q16_16);  // 3.0 + (-1.0) = 2.0 expected
    let digest = sha256_q16(result);
    let expected: [u8; 32] = *b"PLACEHOLDER_HASH_ADD____________"; // 32 bytes
