        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert!(result.is_err());
}

// All-zero model_hash is structurally valid (zeros are a legal SHA-256 preimage
// output only in adversarial contexts, but emit must not special-case it).
#[test]
fn test_envelope_emit_accepts_all_zero_model_hash() {
    let result = emit(
        zeros32(),
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert!(result.is_ok());
}

// Two calls with all-zero hashes and differing only in timestamp produce
// distinct chain_curr — timestamp enters the hash.
#[test]
fn test_chain_timestamp_discriminates_chain_curr() {
    let make_cc = |ts: i64| -> [u8; 32] {
        let bytes = emit(
            PLACEHOLDER_HASH_MODEL,
            PLACEHOLDER_HASH_TOKENIZER,
            PLACEHOLDER_HASH_CATALOG,
            PLACEHOLDER_HASH_REQUEST,
            PLACEHOLDER_HASH_RESULT,
            k             = DEFAULT_K,
            wire_version  = DEFAULT_WIRE_VERSION,
            architecture  = DEFAULT_ARCH,
            timestamp_ms  = ts,
            entry_kind    = EntryKind::Inference,
            chain_prev    = zeros32(),
            chain_reset_reason = ChainResetReason::Continuation,
        );
        let (_, cc) = verify(bytes, zeros32()).unwrap();
        cc
    };

    assert_ne!(make_cc(1_000_000), make_cc(1_000_001));
}

// Verifying a valid envelope against a WRONG expected chain_prev returns
// ChainBroken (the envelope's own chain_prev field doesn't match what we
// supply as the expected predecessor hash).
#[test]
fn test_chain_verify_rejects_wrong_expected_predecessor() {
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),   // envelope records zeros as predecessor
        chain_reset_reason = ChainResetReason::Continuation,
    );
    // Tell verify we expect a non-zero predecessor — mismatch.
    let wrong_predecessor = [0xFFu8; 32];
    let result = verify(bytes, wrong_predecessor);
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::ChainBroken);
}

// ---------------------------------------------------------------------------
// §12. request_hash non-zero invariant (SOTA-track #2)
//
// request_hash MUST be non-zero in every valid envelope. An all-zero
// request_hash is ambiguous with the chain-start sentinel used by chain_prev
// and signals an uninitialised or scrubbed input fingerprint. The verifier
// MUST reject such envelopes with ZeroRequestHash rather than silently
// attesting over an unbound request.
//
// emit() enforces this on construction; verify() / deserialize() enforces it
// on the inbound path so that replayed or hand-crafted envelopes cannot bypass
// the check.
// ---------------------------------------------------------------------------

// RED: verify() must reject an envelope whose request_hash bytes are all zero.
// This test FAILS before the verifier invariant is added.
#[test]
fn test_verify_rejects_zero_request_hash() {
    // Build an otherwise-valid envelope but with request_hash forced to zeros.
    // We bypass emit()'s construction-time gate by directly patching the bytes
    // after serialization, mimicking a replayed / hand-crafted envelope.
    let bytes = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        PLACEHOLDER_HASH_REQUEST,   // non-zero on construction
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    // Overwrite the request_hash field (offset 116..148) with zeros to
    // simulate an uninitialised or scrubbed fingerprint.
    let mut tampered = bytes.clone();
    let mut idx: usize = 116;
    while idx < 148 {
        tampered[idx] = 0u8;
        idx = idx + 1;
    }
    let result = verify(tampered, zeros32());
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::ZeroRequestHash);
}

// RED: emit() must refuse to construct an envelope with an all-zero request_hash.
#[test]
fn test_emit_rejects_zero_request_hash() {
    let result = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        zeros32(),                  // zero request_hash — must be rejected
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), VerificationError::ZeroRequestHash);
}

// GREEN guard: a non-zero request_hash (even a single non-zero byte) is accepted.
#[test]
fn test_emit_accepts_nonzero_request_hash() {
    let mut nonzero_request: [u8; 32] = [0u8; 32];
    nonzero_request[0] = 0x01u8;
    let result = emit(
        PLACEHOLDER_HASH_MODEL,
        PLACEHOLDER_HASH_TOKENIZER,
        PLACEHOLDER_HASH_CATALOG,
        nonzero_request,
        PLACEHOLDER_HASH_RESULT,
        k             = DEFAULT_K,
        wire_version  = DEFAULT_WIRE_VERSION,
        architecture  = DEFAULT_ARCH,
        timestamp_ms  = DEFAULT_TIMESTAMP,
        entry_kind    = EntryKind::Inference,
        chain_prev    = zeros32(),
        chain_reset_reason = ChainResetReason::Continuation,
    );
    assert!(result.is_ok());
}

// TODO(P1.1.16): replace any PLACEHOLDER_HASH_* after first green run.
